# === Backend (set these on Render) ===

# PostgreSQL connection string from Neon / Supabase / Render Postgres
# For local dev, leave unset to use SQLite automatically
DATABASE_URL=postgresql://user:password@host/dbname

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Comma-separated allowed frontend origins for CORS
# Example: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# === Frontend (set these on Vercel) ===

# Backend API URL (set at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
